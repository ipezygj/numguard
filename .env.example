# copy to .env and fill in. NEVER commit .env (it holds a private key).

# Your RECEIVING wallet — USDC payments land here. Public address only; no key needed. (already yours)
NUMGUARD_PAYTO=0x75c5487C44E0EA83E5F2f692BF301500a40B836f

# The facilitator's SIGNER wallet — pays gas to settle payments on-chain.
# ⚠️ Use a DEDICATED wallet funded with a little ETH on Base ONLY. NOT your main wallet, NOT NUMGUARD_PAYTO.
# It never holds USDC; it just broadcasts the transfers. Compromise = at most its small gas balance.
FACILITATOR_PRIVATE_KEY=0xREPLACE_WITH_A_DEDICATED_GAS_WALLET_PRIVATE_KEY

# Network: start on testnet (free test-USDC), flip to 'base' for real payments.
NUMGUARD_NETWORK=base-sepolia
